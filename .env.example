# PostgreSQL
POSTGRES_USER=utservio
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=utservio_ci
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Application
CI_APP_PORT=8000
CI_WORKERS=1
CI_LOG_LEVEL=info
CI_DEBUG=false
CI_ENVIRONMENT=development

# Database URL
DATABASE_URL=postgresql+asyncpg://utservio:changeme_in_production@localhost:5432/utservio_ci
CI_DATABASE__URL=postgresql+asyncpg://utservio:changeme_in_production@localhost:5432/utservio_ci

# API Key (required for production, leave empty for development)
CI_API_KEY=

# Collection defaults
CI_COLLECTOR__MAX_CONCURRENT_REQUESTS=10
CI_COLLECTOR__COLLECTION_TIMEOUT=300
CI_COLLECTOR__RATE_LIMIT_PER_SECOND=0.5
CI_COLLECTOR__USER_AGENT=UtservioCI/1.0
CI_COLLECTOR__RETRY_ATTEMPTS=3
CI_COLLECTOR__RETRY_DELAY=1.0

# Scheduler
CI_SCHEDULER__ENABLED=true
CI_SCHEDULER__CHECK_INTERVAL_SECONDS=60

# Competitor configuration path
CI_COMPETITORS_CONFIG_PATH=./competitors.json